generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String           @id @default(cuid())
  email            String?          @unique
  name             String?
  image            String?
  emailVerified    DateTime?
  subscriptionTier SubscriptionTier @default(FREE)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  accounts     Account[]
  sessions     Session[]
  auditReports AuditReport[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model AuditReport {
  id           String      @id @default(cuid())
  userId       String?
  url          String
  urlHash      String
  status       AuditStatus @default(PENDING)
  overallScore Int?
  errorMessage String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  completedAt  DateTime?

  user     User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  sections AuditSection[]
  issues   AuditIssue[]

  @@index([userId])
  @@index([urlHash])
  @@index([status])
  @@index([createdAt])
  @@map("audit_reports")
}

model AuditSection {
  id       String @id @default(cuid())
  reportId String
  category String
  score    Int
  data     Json

  report AuditReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@map("audit_sections")
}

model AuditIssue {
  id             String        @id @default(cuid())
  reportId       String
  category       String
  severity       IssueSeverity
  title          String
  description    String
  recommendation String
  createdAt      DateTime      @default(now())

  report AuditReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([severity])
  @@map("audit_issues")
}

enum AuditStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum IssueSeverity {
  CRITICAL
  WARNING
  PASSED
}

enum SubscriptionTier {
  FREE
  PRO
  ENTERPRISE
}
