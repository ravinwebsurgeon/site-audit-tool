generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String           @id @default(cuid())
  email            String?          @unique
  name             String?
  image            String?
  emailVerified    DateTime?
  subscriptionTier SubscriptionTier @default(FREE)
  onboardingDone   Boolean          @default(false)
  notifyOnComplete Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  accounts         Account[]
  sessions         Session[]
  auditReports     AuditReport[]
  siteAuditReports SiteAuditReport[]
  subscription     Subscription?
  schedules        Schedule[]
  apiKeys          ApiKey[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Subscription {
  id             String          @id @default(cuid())
  userId         String          @unique
  tier           SubscriptionTier @default(FREE)
  status         SubStatus        @default(ACTIVE)
  auditsPerDay   Int              @default(5)
  startedAt      DateTime         @default(now())
  expiresAt      DateTime?
  stripeCustomer String?
  stripePriceId  String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model SiteAuditReport {
  id             String      @id @default(cuid())
  userId         String?
  rootUrl        String
  urlHash        String
  status         AuditStatus @default(PENDING)
  totalPages     Int         @default(0)
  completedPages Int         @default(0)
  failedPages    Int         @default(0)
  avgScore       Float?
  sitemapUrl     String?
  pagesLimit     Int         @default(10)
  errorMessage   String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  completedAt    DateTime?

  user        User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  pageReports AuditReport[]

  @@index([userId])
  @@index([urlHash])
  @@index([status])
  @@map("site_audit_reports")
}

model AuditReport {
  id           String      @id @default(cuid())
  userId       String?
  url          String
  urlHash      String
  status       AuditStatus @default(PENDING)
  overallScore Int?
  errorMessage String?
  siteAuditId  String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  completedAt  DateTime?

  user      User?            @relation(fields: [userId], references: [id], onDelete: Cascade)
  siteAudit SiteAuditReport? @relation(fields: [siteAuditId], references: [id], onDelete: Cascade)
  sections  AuditSection[]
  issues    AuditIssue[]

  @@index([userId])
  @@index([urlHash])
  @@index([status])
  @@index([siteAuditId])
  @@index([createdAt])
  @@map("audit_reports")
}

model AuditSection {
  id       String @id @default(cuid())
  reportId String
  category String
  score    Int
  data     Json

  report AuditReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@map("audit_sections")
}

model AuditIssue {
  id             String        @id @default(cuid())
  reportId       String
  category       String
  severity       IssueSeverity
  title          String
  description    String
  recommendation String
  createdAt      DateTime      @default(now())

  report AuditReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([severity])
  @@map("audit_issues")
}

model Schedule {
  id           String            @id @default(cuid())
  userId       String
  url          String
  frequency    ScheduleFrequency
  isActive     Boolean           @default(true)
  nextRunAt    DateTime
  lastRunAt    DateTime?
  lastReportId String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([nextRunAt, isActive])
  @@map("schedules")
}

model ApiKey {
  id         String    @id @default(cuid())
  userId     String
  name       String
  keyHash    String    @unique
  prefix     String
  lastUsedAt DateTime?
  expiresAt  DateTime?
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("api_keys")
}

enum AuditStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum ScheduleFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

enum IssueSeverity {
  CRITICAL
  WARNING
  PASSED
}

enum SubscriptionTier {
  FREE
  PRO
  ENTERPRISE
}

enum SubStatus {
  ACTIVE
  CANCELLED
  EXPIRED
}
